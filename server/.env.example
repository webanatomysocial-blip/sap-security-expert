DB_CONNECTION=mysql
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_username
DB_PASS=your_database_password
DB_CHARSET=utf8mb4

# Express server
EXPRESS_PORT=3001
SESSION_SECRET=change_this_to_a_random_secret_string

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=SAP Security Expert

# Site
SITE_URL=https://sap.webanatomy.in
CANONICAL_URL=https://sap.webanatomy.in
ADMIN_EMAIL=hello@sap.webanatomy.in
CRON_SECRET=change_this_to_a_random_secret

# Plagiarism API (optional)
PLAGIARISM_API_TOKEN=

# Razorpay — get keys from https://dashboard.razorpay.com/app/keys
# Use rzp_test_* keys for testing, rzp_live_* for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
